{
  "name": "@fatal-error/jasmine-contracts",
  "version": "0.1.5",
  "description": "Shared runtime contract for Jasmine Workspace and Jasmine Control Plane.",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./session-context": {
      "types": "./dist/session-context/index.d.ts",
      "import": "./dist/session-context/index.js"
    },
    "./entitlements": {
      "types": "./dist/entitlements/index.d.ts",
      "import": "./dist/entitlements/index.js"
    },
    "./integrations": {
      "types": "./dist/integrations/index.d.ts",
      "import": "./dist/integrations/index.js"
    },
    "./tenant": {
      "types": "./dist/tenant/index.d.ts",
      "import": "./dist/tenant/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "scripts": {
    "clean": "rm -rf dist .tsup",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": [
    "jasmine",
    "contracts",
    "typescript",
    "entitlements",
    "session-context"
  ],
  "author": "OpenAI for Adriano",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Fatal-Error/jasmine-contracts.git"
  }
}
